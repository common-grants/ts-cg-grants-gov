{
  "name": "@common-grants/cg-grants-gov",
  "description": "A CommonGrants adapter library for the Simpler.Grants.gov API",
  "version": "0.2.0",
  "license": "CC0-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/common-grants/ts-cg-grants-gov.git"
  },
  "homepage": "https://github.com/common-grants/ts-cg-grants-gov#readme",
  "bugs": {
    "url": "https://github.com/common-grants/ts-cg-grants-gov/issues"
  },
  "keywords": [
    "common-grants",
    "grants-gov",
    "plugin",
    "typescript",
    "grants",
    "opportunities"
  ],
  "packageManager": "pnpm@10.34.3",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint . --fix",
    "check:lint": "eslint .",
    "format": "prettier --write .",
    "check:format": "prettier --check .",
    "check:types": "tsc --noEmit",
    "checks": "pnpm run check:lint && pnpm run check:format && pnpm run check:types",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "ci": "pnpm run checks && pnpm run build && pnpm run test && pnpm audit",
    "example:parse": "pnpm dlx tsx examples/parse-opportunity.ts",
    "example:filters": "pnpm dlx tsx examples/search-with-filters.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "@common-grants/sdk": "^0.5.0"
  },
  "pnpm": {
    "overrides": {
      "zod": "3.25.76"
    }
  },
  "devDependencies": {
    "@common-grants/sdk": "^0.5.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.20.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.9",
    "zod": "^3.25.0"
  }
}
